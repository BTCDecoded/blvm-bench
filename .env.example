# Copy to `.env` in this directory (or export in your shell). Never commit `.env`.
#
# ── block_kernel_diff (kernel differential) ─────────────────────────────────
# Prefer a gitignored file so LAN RPC secrets stay local:
#   cp .env.example kernel-diff.local.env   # then edit; kernel-diff.local.env is in .gitignore
# Or: .env.local
# load_kernel_diff_env() and scripts/restart-kernel-diff-500k.sh read (first match):
#   KERNEL_DIFF_ENV_FILE, kernel-diff.local.env, blvm-bench/.env.local, .env
#
# Layout: BLOCK_CACHE_DIR = SSD (chunks + utxo_*.bin checkpoints). Databases on NVMe only:
# KERNEL_DIFF_NVME_ROOT=/home/you   # default parent for CORE_DATADIR + DISK_UTXO_PATH in restart script
# Or set absolute paths:
# CORE_DATADIR=/home/you/kernel-diff-chainstate
# DISK_UTXO_PATH=/home/you/kernel-diff-disk-utxo
#
# Default run (restart-kernel-diff-500k.sh): KERNEL_DIFF_END=900001 KERNEL_DIFF_ASSUME=938343 unless overridden.
#
# LAN Bitcoin Core (e.g. Start9) — direct JSON-RPC for chunk seek fallback:
# BITCOIN_RPC_HOST=192.168.x.x
# BITCOIN_RPC_PORT=8332
# BITCOIN_RPC_USER=
# BITCOIN_RPC_PASSWORD=
# If BITCOIN_RPC_* are unset, START9_RPC_* / LAND_NODE_RPC_* / REMOTE_CORE_RPC_* are tried (see RpcConfig::from_env).
# BITCOIN_NETWORK=mainnet
# Large zstd seek avoidance (0 = off): fetch blocks via RPC for rest of run when seek would exceed this.
# KERNEL_DIFF_RPC_CHUNK_SKIP_MB=128
#
# Root of your local chunk cache (chunks.meta, chunk_*.bin.zst).
BLOCK_CACHE_DIR=

# Optional: sort-merge intermediates (defaults to $BLOCK_CACHE_DIR/sort_merge_data).
# SORT_MERGE_DIR=

# Bitcoin Core data directory containing a `blocks/` subdir (`fill_missing_from_files`, parallel differential direct read).
# BITCOIN_DATA_DIR=

# Optional extra datadirs (platform path-list, same separators as PATH). Tried after BITCOIN_DATA_DIR.
# BITCOIN_DATA_DIRS=

# Directory that directly contains blk*.dat (`recollect_blocks`).
# BITCOIN_BLK_DIR=

# Remote Bitcoin Core over SSH + nsenter (`remote_core_rpc`, `collect_chunks_rpc`, etc.).
# Used by scripts/chunk-utxo-resume-with-fallback.sh when CHUNK_UTXO_FALLBACK_COLLECT=1 (chunk repair).
# REMOTE_CORE_SSH_KEY=
# REMOTE_CORE_SSH_HOST=
# REMOTE_CORE_RPC_USER=
# REMOTE_CORE_RPC_PASSWORD=
# XOR / out-of-order blk trees (optional): REMOTE_CORE_XOR_BLOCKFILES=1
# Legacy env names still work: LAND_NODE_* then START9_*.
#
# Chunk UTXO checkpoints: copy this file to `.env` in this directory (or set BLVM_BENCH_ENV_FILE).
# BLVM_BENCH_ENV_FILE=/absolute/path/to/.env
# CHUNK_UTXO_FALLBACK_COLLECT=1   # optional: after resume failure, run collect_chunks_rpc then retry
# DISK_UTXO_DB_PATH=              # optional; default ~/.cache/blvm-bench/utxo_rocksdb

# Integration: fail `tests/integration.rs` historical differential when any divergence (default: report only).
# DIFF_FAIL_ON_DIVERGENCE=1
